<Window x:Class="SimpleCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Simple Calculator"
        Height="500"
        Width="350"
        MinHeight="450"
        MinWidth="320"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="Display"
                 Grid.Row="0"
                 Height="70"
                 Margin="0,0,0,10"
                 FontSize="28"
                 Text="0"
                 IsReadOnly="True"
                 HorizontalContentAlignment="Right"
                 VerticalContentAlignment="Center"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Row 0 -->
            <Button Grid.Row="0" Grid.Column="0" Content="C" FontSize="22" Margin="5" Click="ClearButton_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="/" FontSize="22" Margin="5" Click="OperatorButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="*" FontSize="22" Margin="5" Click="OperatorButton_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="-" FontSize="22" Margin="5" Click="OperatorButton_Click"/>

            <!-- Row 1 -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="+" FontSize="22" Margin="5" Grid.RowSpan="2" Click="OperatorButton_Click"/>

            <!-- Row 2 -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" FontSize="22" Margin="5" Click="DigitButton_Click"/>

            <!-- Row 3 -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" FontSize="22" Margin="5" Click="DigitButton_Click"/>
            <Button Grid.Row="3" Grid.Column="3" Content="=" FontSize="22" Margin="5" Grid.RowSpan="2" Click="EqualsButton_Click"/>

            <!-- Row 4 -->
            <Button Grid.Row="4" Grid.Column="0" Content="0" FontSize="22" Margin="5" Grid.ColumnSpan="2" Click="DigitButton_Click"/>
            <Button Grid.Row="4" Grid.Column="2" Content="." FontSize="22" Margin="5" Click="DecimalButton_Click"/>
        </Grid>
    </Grid>
</Window>